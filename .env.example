# Copy to .env and edit before `docker compose up`.

# Comma-separated list of origins allowed by CORS. Must include your web origin.
CORS_ORIGINS=http://localhost:3000

# URL the browser will hit to call the API. If you run docker on a remote host,
# replace this with the public URL of the api service.
PUBLIC_API_URL=http://localhost:3002

# REQUIRED for production. Generate with: openssl rand -base64 48
# Must match AgentGate's JWT_SECRET if you want tools with auth.type=agentgate
# to verify tokens issued by AgentGate.
AGENTGATE_JWT_SECRET=replace-me-with-a-32-plus-char-secret

# Issuer claim on AgentGate-issued JWTs (default: agentgate)
AGENTGATE_JWT_ISSUER=agentgate

# Per-IP-per-minute rate limits (tune for your scale)
RATE_LIMIT_READ_PER_MINUTE=240
RATE_LIMIT_WRITE_PER_MINUTE=20
RATE_LIMIT_CALL_PER_MINUTE=60

# pino log level
LOG_LEVEL=info
